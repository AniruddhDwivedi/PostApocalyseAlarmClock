  <property name="styleSheet">
   <string notr="true">/* Style the Dialog background */
QDialog {
    background-color: #f5f5f5;
}

/* Ensure inputs are readable */
QLineEdit, QSpinBox {
    background-color: white;
    color: #2c3e50; /* Dark blue/grey text */
    border: 1px solid #bdc3c7;
    padding: 4px;
}

/* Style the checkboxes for the days */
QCheckBox {
    color: #2c3e50;
    font-size: 11px;
    spacing: 5px;
}

/* Add a bit of hover effect to the checkboxes */
QCheckBox::indicator:hover {
    background-color: #ebf5ff;
}
/* Style the Add Button */
QPushButton {
    background-color: #0078d7;
    color: white;
    border-radius: 8px;
    padding: 10px;
    font-weight: bold;
    margin-top: 10px;
}

QPushButton:hover {
    background-color: #005a9e;
}

QCheckBox{
color: green;
}</string>
